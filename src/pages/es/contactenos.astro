---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Contáctenos | Mister Mortgage USA | Miami FL (305) 615-1515"
  description="Contacta a Mister Mortgage USA — el broker hipotecario de confianza en Miami. Llama al (305) 615-1515 o visítanos en 6030 Bird Rd, Miami, FL 33155. NMLS #2572035."
  lang="es"
  canonical="https://mistermortgageusa.com/es/contactenos"
  altLang="/contact-us"
>

  <section class="loan-hero" style="background-image:url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&q=80')">
    <div class="loan-hero-overlay"></div>
    <div class="loan-hero-content section-inner reveal">
      <span class="section-label" data-i18n="contact.hero.label">Estamos Aquí para Ayudarte</span>
      <h1 data-i18n="contact.hero.h1">Contacta a <em>Mister Mortgage USA</em></h1>
      <p data-i18n="contact.hero.body">¿Tienes preguntas sobre tus opciones hipotecarias? ¿Listo para comenzar el proceso de precalificación? Nuestros expertos están disponibles — contáctanos hoy.</p>
      <a class="btn btn-red" href="tel:+13056151515">(305) 615-1515</a>
    </div>
  </section>

  <section class="section" style="padding:80px 0;">
    <div class="section-inner">
      <div class="contact-layout" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;">

        <div class="reveal">
          <span class="section-label" data-i18n="contact.info.label">Encuéntranos</span>
          <h2 style="margin-bottom:40px;" data-i18n="contact.info.title">Contáctanos <em>Hoy</em></h2>

          <div class="contact-info-list">
            <div class="contact-info-item">
              <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
              <div>
                <strong data-i18n="contact.address.label">Dirección de la Oficina</strong>
                <p>6030 Bird Rd<br />Miami, FL 33155</p>
              </div>
            </div>
            <div class="contact-info-item">
              <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.12 2.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.45-.45a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
              <div>
                <strong data-i18n="contact.phone.label">Teléfono</strong>
                <p><a href="tel:+13056151515">(305) 615-1515</a></p>
              </div>
            </div>
            <div class="contact-info-item">
              <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
              <div>
                <strong data-i18n="contact.wa.label">WhatsApp</strong>
                <p><a href="https://wa.me/13056151515" target="_blank" rel="noopener" data-i18n="contact.wa.link">Chatea con nosotros por WhatsApp</a></p>
              </div>
            </div>
            <div class="contact-info-item">
              <div class="contact-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div>
                <strong data-i18n="contact.hours.label">Horario de Atención</strong>
                <p data-i18n="contact.hours.body">Lunes – Viernes: 9:00 AM – 6:00 PM<br />Sábado: 10:00 AM – 3:00 PM<br />Domingo: Con cita previa</p>
              </div>
            </div>
            <div class="contact-info-item">
              <div class="contact-icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
              <div>
                <strong data-i18n="contact.license.label">Licencia</strong>
                <p>NMLS #2572035</p>
              </div>
            </div>
          </div>

          <div style="margin-top:40px;border-radius:12px;overflow:hidden;border:1px solid var(--border);">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3593.3156953780697!2d-80.32236!3d25.7296!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d9b9b7e5b9999b%3A0x0!2s6030+Bird+Rd%2C+Miami%2C+FL+33155!5e0!3m2!1ses!2sus!4v1234567890"
              width="100%"
              height="280"
              style="border:0;display:block;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Mister Mortgage USA"
            ></iframe>
          </div>
        </div>

        <div class="reveal">
          <span class="section-label" data-i18n="contact.form.label">Envíanos un Mensaje</span>
          <h2 style="margin-bottom:40px;" data-i18n="contact.form.title">Te Responderemos <em>Rápidamente</em></h2>

          <form id="contact-form" class="contact-form" onsubmit="handleFormSubmit(event,'contact-form','contact-form-msg')">
            <div class="form-group">
              <label for="cf-name" data-i18n="contact.form.name">Nombre Completo *</label>
              <input type="text" id="cf-name" name="name" placeholder="Juan García" required />
            </div>
            <div class="form-group">
              <label for="cf-email" data-i18n="contact.form.email">Correo Electrónico *</label>
              <input type="email" id="cf-email" name="email" placeholder="juan@ejemplo.com" required />
            </div>
            <div class="form-group">
              <label for="cf-phone" data-i18n="contact.form.phone">Número de Teléfono</label>
              <input type="tel" id="cf-phone" name="phone" placeholder="(305) 000-0000" />
            </div>
            <div class="form-group">
              <label for="cf-subject" data-i18n="contact.form.subject">Asunto</label>
              <select id="cf-subject" name="subject">
                <option value="" data-i18n="contact.form.subj.default">Selecciona un tema...</option>
                <option value="pre-qualification" data-i18n="contact.form.subj.prequal">Precalificación</option>
                <option value="purchase" data-i18n="contact.form.subj.purchase">Compra de Vivienda</option>
                <option value="refinance" data-i18n="contact.form.subj.refi">Refinanciamiento</option>
                <option value="investment" data-i18n="contact.form.subj.invest">Propiedad de Inversión</option>
                <option value="general" data-i18n="contact.form.subj.general">Pregunta General</option>
              </select>
            </div>
            <div class="form-group">
              <label for="cf-message" data-i18n="contact.form.message">Mensaje *</label>
              <textarea id="cf-message" name="message" rows="5" placeholder="Cuéntanos sobre tus necesidades hipotecarias..." data-i18n-placeholder="contact.form.placeholder" required></textarea>
            </div>
            <button type="submit" class="btn btn-red" style="width:100%;justify-content:center;" data-i18n="contact.form.send">Enviar Mensaje</button>
            <p id="contact-form-msg" style="margin-top:16px;text-align:center;color:var(--accent-green);display:none;"></p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="cta-band-bg"></div>
    <div class="cta-band-overlay"></div>
    <div class="cta-band-content section-inner">
      <span class="section-label" data-i18n="contact.cta.label">Acelera tu Aprobación</span>
      <h2 data-i18n="contact.cta.title">Comienza tu Precalificación <em>en Minutos</em></h2>
      <p data-i18n="contact.cta.body">Nuestro formulario de precalificación rápida toma solo unos minutos. Descubre hoy cuánto puedes pagar por tu casa.</p>
      <div class="cta-band-actions">
        <a class="btn btn-red" href="#" onclick="openPrequalModal();return false;"><span data-i18n="nav.cta">PRECALIFÍQUESE AHORA</span></a>
        <a class="btn btn-outline-white" href="/es/opciones-de-prestamo" data-i18n="contact.cta.btn2">Ver Opciones de Préstamo</a>
      </div>
    </div>
  </div>

</MainLayout>
