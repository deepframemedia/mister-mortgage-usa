---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Contact Us | Mister Mortgage USA | Miami FL (305) 615-1515"
  description="Contact Mister Mortgage USA — Miami's trusted mortgage broker. Call (305) 615-1515 or visit us at 6030 Bird Rd, Miami, FL 33155. NMLS #2572035."
  lang="en"
  canonical="https://mistermortgageusa.com/contact-us"
  altLang="/es/contactenos"
>

  <section class="loan-hero" style="background-image:url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&q=80')">
    <div class="loan-hero-overlay"></div>
    <div class="loan-hero-content section-inner reveal">
      <span class="section-label" data-i18n="contact.hero.label">We're Here to Help</span>
      <h1 data-i18n="contact.hero.h1">Contact <em>Mister Mortgage USA</em></h1>
      <p data-i18n="contact.hero.body">Have questions about your mortgage options? Ready to start the pre-qualification process? Our experts are standing by — reach out today.</p>
      <a class="btn btn-red" href="tel:+13056151515">(305) 615-1515</a>
    </div>
  </section>

  <section class="section" style="padding:80px 0;">
    <div class="section-inner">
      <div class="contact-layout" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;">

        <div class="reveal">
          <span class="section-label" data-i18n="contact.info.label">Reach Us</span>
          <h2 style="margin-bottom:40px;" data-i18n="contact.info.title">Get in Touch <em>Today</em></h2>

          <div class="contact-cards">
            <a href="https://maps.google.com/?q=6030+Bird+Rd+Miami+FL+33155" target="_blank" rel="noopener" class="contact-card">
              <div class="contact-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-card-label" data-i18n="contact.address.label">Office Address</span>
                <p class="contact-card-value">6030 Bird Rd<br />Miami, FL 33155</p>
              </div>
              <svg class="contact-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="tel:+13056151515" class="contact-card">
              <div class="contact-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.12 2.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.45-.45a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-card-label" data-i18n="contact.phone.label">Phone</span>
                <p class="contact-card-value">(305) 615-1515</p>
              </div>
              <svg class="contact-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <a href="https://wa.me/13052141515?text=Hi!%20I%27m%20reaching%20out%20from%20your%20Contact%20page.%20I%27d%20like%20to%20learn%20more%20about%20my%20mortgage%20options." target="_blank" rel="noopener" class="contact-card">
              <div class="contact-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-card-label" data-i18n="contact.wa.label">WhatsApp</span>
                <p class="contact-card-value" data-i18n="contact.wa.link">Chat with us on WhatsApp</p>
              </div>
              <svg class="contact-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <div class="contact-card contact-card--static">
              <div class="contact-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-card-label" data-i18n="contact.hours.label">Business Hours</span>
                <p class="contact-card-value" data-i18n="contact.hours.body">Mon – Fri: 9:00 AM – 6:00 PM<br />Sat – Sun: By appointment only</p>
              </div>
            </div>

            <div class="contact-card contact-card--static contact-card--license">
              <div class="contact-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="contact-card-body">
                <span class="contact-card-label" data-i18n="contact.license.label">License</span>
                <p class="contact-card-value">NMLS #2572035</p>
              </div>
            </div>
          </div>

          <div style="margin-top:32px;border-radius:12px;overflow:hidden;border:1px solid var(--border);">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3593.3156953780697!2d-80.32236!3d25.7296!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d9b9b7e5b9999b%3A0x0!2s6030+Bird+Rd%2C+Miami%2C+FL+33155!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="260"
              style="border:0;display:block;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Mister Mortgage USA Office Location"
            ></iframe>
          </div>
        </div>

        <div class="reveal">
          <span class="section-label" data-i18n="contact.form.label">Send a Message</span>
          <h2 style="margin-bottom:40px;" data-i18n="contact.form.title">We'll Get Back to <em>You Quickly</em></h2>

          <form id="contact-form" class="contact-form" onsubmit="handleFormSubmit(event,'contact-form','contact-form-msg')">
            <div class="form-group">
              <label for="cf-name" data-i18n="contact.form.name">Full Name *</label>
              <input type="text" id="cf-name" name="name" placeholder="John Smith" required />
            </div>
            <div class="form-group">
              <label for="cf-email" data-i18n="contact.form.email">Email Address *</label>
              <input type="email" id="cf-email" name="email" placeholder="john@example.com" required />
            </div>
            <div class="form-group">
              <label for="cf-phone" data-i18n="contact.form.phone">Phone Number</label>
              <input type="tel" id="cf-phone" name="phone" placeholder="(305) 000-0000" />
            </div>
            <div class="form-group">
              <label for="cf-subject" data-i18n="contact.form.subject">Subject</label>
              <select id="cf-subject" name="subject">
                <option value="" data-i18n="contact.form.subj.default">Select a topic...</option>
                <option value="pre-qualification" data-i18n="contact.form.subj.prequal">Get Pre-Qualified</option>
                <option value="purchase" data-i18n="contact.form.subj.purchase">Home Purchase</option>
                <option value="refinance" data-i18n="contact.form.subj.refi">Refinance</option>
                <option value="investment" data-i18n="contact.form.subj.invest">Investment Property</option>
                <option value="general" data-i18n="contact.form.subj.general">General Question</option>
              </select>
            </div>
            <div class="form-group">
              <label for="cf-message" data-i18n="contact.form.message">Message *</label>
              <textarea id="cf-message" name="message" rows="5" placeholder="Tell us about your mortgage needs..." data-i18n-placeholder="contact.form.placeholder" required></textarea>
            </div>
            <button type="submit" class="btn btn-red" style="width:100%;justify-content:center;" data-i18n="contact.form.send">Send Message</button>
            <p id="contact-form-msg" style="margin-top:16px;text-align:center;color:var(--accent-green);display:none;"></p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="cta-band-bg"></div>
    <div class="cta-band-overlay"></div>
    <div class="cta-band-content section-inner">
      <span class="section-label" data-i18n="contact.cta.label">Fast-Track Your Approval</span>
      <h2 data-i18n="contact.cta.title">Start Your Pre-Qualification <em>in Minutes</em></h2>
      <p data-i18n="contact.cta.body">Our quick pre-qualification form takes just a few minutes. Find out how much home you can afford today.</p>
      <div class="cta-band-actions">
        <a class="btn btn-red" href="#" onclick="openPrequalModal();return false;"><span data-i18n="nav.cta">GET PRE-QUALIFIED NOW</span></a>
        <a class="btn btn-outline-white" href="/loan-options" data-i18n="contact.cta.btn2">View Loan Options</a>
      </div>
    </div>
  </div>

</MainLayout>
