---
import type { Lang } from '../data/nav';
import { navLinks } from '../data/nav';

export interface Props { lang: Lang; }
const { lang } = Astro.props;
const nav = navLinks[lang];

const loanLinks = lang === 'en' ? [
  { href: '/fixed-rate-mortgage-miami',     label: 'Fixed Rate',        i18n: 'loan.fixed' },
  { href: '/fha-home-loan-miami',            label: 'FHA Home Loan',     i18n: 'loan.fha' },
  { href: '/low-down-payment-mortgage',      label: 'Low Down Payment',  i18n: 'loan.lowdown' },
  { href: '/rehab-loan-203k',               label: 'Rehab Loans',       i18n: 'loan.rehab' },
  { href: '/usda-loan-florida',             label: 'USDA Loan',         i18n: 'loan.usda' },
  { href: '/jumbo-loans-miami',             label: 'Jumbo Loans',       i18n: 'loan.jumbo' },
  { href: '/va-home-loan-miami',            label: 'VA Home Loan',      i18n: 'loan.va' },
  { href: '/first-time-homebuyer-miami',    label: 'First-Time Homebuyer', i18n: 'loan.ftb' },
  { href: '/investment-property-loans-miami', label: 'Investment Property', i18n: 'loan.invest' },
  { href: '/mortgage-refinance-miami',      label: 'Refinance',         i18n: 'loan.refi' },
] : [
  { href: '/es/hipoteca-tasa-fija-miami',        label: 'Tasa Fija',              i18n: 'loan.fixed' },
  { href: '/es/prestamo-fha-miami',              label: 'Préstamo FHA',           i18n: 'loan.fha' },
  { href: '/es/hipoteca-bajo-enganche',          label: 'Bajo Enganche',          i18n: 'loan.lowdown' },
  { href: '/es/prestamo-rehabilitacion-203k',   label: 'Rehab 203k',             i18n: 'loan.rehab' },
  { href: '/es/prestamo-usda-florida',          label: 'USDA',                   i18n: 'loan.usda' },
  { href: '/es/prestamos-jumbo-miami',          label: 'Jumbo',                  i18n: 'loan.jumbo' },
  { href: '/es/prestamo-va-miami',              label: 'VA',                     i18n: 'loan.va' },
  { href: '/es/primer-comprador-miami',         label: 'Primer Comprador',       i18n: 'loan.ftb' },
  { href: '/es/prestamos-propiedad-inversion',  label: 'Propiedad de Inversión', i18n: 'loan.invest' },
  { href: '/es/refinanciar-hipoteca-miami',     label: 'Refinanciamiento',       i18n: 'loan.refi' },
];
---

<footer id="footer" aria-label="Footer">
  <div class="container">
    <div class="footer-top">

      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="https://mistermortgageusa.com/wp-content/uploads/2025/05/PNG-02.webp" alt="Mister Mortgage USA" />
        </div>
        <p><span data-i18n="footer.tagline">The key to our success is to consistently offer the lowest possible price and, above all, to provide excellent customer service. We pride ourselves on treating our customers with honesty and integrity.</span></p>
        <span class="footer-nmls">NMLS #2572035</span>
        <div class="footer-social">
          <a href="https://www.tiktok.com/@mistermortgageusa" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.03a8.16 8.16 0 004.79 1.54V7.12a4.85 4.85 0 01-1.02-.43z"/></svg>
          </a>
          <a href="https://www.facebook.com/mistermortgageUSA/" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/mistermortgageusa/?hl=en" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://www.youtube.com/channel/UCbut-g1_SQtZQ8be-kWvISw" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
          <a href="https://x.com/Mrmortgageusa" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- Loan Options -->
      <div class="footer-col">
        <h4><span data-i18n="footer.col.loans">Loan Options</span></h4>
        <ul>
          {loanLinks.map(l => (
            <li><a href={l.href}><span data-i18n={l.i18n}>{l.label}</span></a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h4><span data-i18n="footer.col.company">Company</span></h4>
        <ul>
          <li><a href={nav.home}><span data-i18n="footer.link.home">Home</span></a></li>
          <li><a href={nav.about}><span data-i18n="footer.link.about">About Us</span></a></li>
          <li><a href={nav.team}><span data-i18n="footer.link.team">Team</span></a></li>
          <li><a href="https://mistermortgageusa.com/blog/" target="_blank" rel="noopener">Blog</a></li>
          <li><a href={nav.contact}><span data-i18n="footer.link.contact">Contact Us</span></a></li>
          <li><a href="#" onclick="openPrequalModal();return false;"><span data-i18n="footer.link.prequal">Get Pre-Qualified</span></a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h4><span data-i18n="footer.col.legal">Legal</span></h4>
        <ul>
          <li><a href="/privacy-policy"><span data-i18n="footer.link.privacy">Privacy Policy</span></a></li>
          <li><a href="/cookie-policy"><span data-i18n="footer.link.cookie">Cookie Policy</span></a></li>
          <li><a href="/government-disclosure"><span data-i18n="footer.link.govdisc">Government Disclosure</span></a></li>
          <li><a href="/customer-complaint-policy"><span data-i18n="footer.link.complaint">Customer Complaint Policy</span></a></li>
          <li><a href="/ada-accessibility"><span data-i18n="footer.link.ada">ADA Accessibility</span></a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        <span data-i18n="footer.copyright">© 2026 Mister Mortgage USA Inc. All rights reserved. NMLS #2572035 | 6030 Bird Rd, Miami, FL 33155 | (305) 615-1515</span>
      </p>
      <p class="footer-powered">Powered by <a href="https://deepframemedia.com" target="_blank" rel="noopener">DeepFrame Media</a></p>
      <div class="footer-eho">
        <svg viewBox="0 0 40 40" width="28" height="28"><rect width="40" height="40" rx="4"/><text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="white" font-size="18" font-weight="bold">⌂</text></svg>
        <span data-i18n="footer.eho">Equal Housing Opportunity</span>
      </div>
    </div>
  </div>
</footer>
