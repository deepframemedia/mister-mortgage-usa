---
import type { Lang } from '../data/nav';
import { navLinks, megaLinks } from '../data/nav';

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const nav  = navLinks[lang];
const mega = megaLinks[lang];

const isActive = (href: string) => {
  if (href === '/' || href === '/es') return currentPath === href || currentPath === href + '/';
  return currentPath === href || currentPath.startsWith(href + '/');
};

const loanPaths = mega.map(l => l.href);
const loansActive = loanPaths.some(p => isActive(p)) || isActive(nav.loans);
---

<nav id="navbar" aria-label="Main navigation">
  <div class="nav-inner">
    <a href={nav.home} class="nav-logo">
      <img src="https://mistermortgageusa.com/wp-content/uploads/2025/05/PNG-02.webp" alt="Mister Mortgage USA" />
    </a>

    <div class="nav-links">
      <a class:list={['nav-link', { active: isActive(nav.home) }]} href={nav.home}>
        <span data-i18n="nav.home">Home</span>
      </a>

      <!-- Mega menu -->
      <div class="nav-mega-wrap">
        <a class:list={['nav-link', { active: loansActive }]} href={nav.loans}>
          <span data-i18n="nav.loans">Loan Options</span>
          <span class="nav-dropdown-arrow">▾</span>
        </a>
        <div class="nav-mega">
          <div class="nav-mega-cols">
            {mega.map(item => (
              <a href={item.href} class:list={['nav-mega-item', { active: isActive(item.href) }]}>
                <div class="nav-mega-item-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                </div>
                <span data-i18n={item.i18n}></span>
              </a>
            ))}
          </div>
          <div class="nav-mega-footer">
            <a href={nav.loans} data-i18n="nav.mega.all">View All Loan Options →</a>
          </div>
        </div>
      </div>

      <a class:list={['nav-link', { active: isActive(nav.about) }]} href={nav.about}>
        <span data-i18n="nav.about">About Us</span>
      </a>
      <a class:list={['nav-link', { active: isActive(nav.team) }]} href={nav.team}>
        <span data-i18n="nav.team">Team</span>
      </a>
      <a class:list={['nav-link', { active: isActive(nav.contact) }]} href={nav.contact}>
        <span data-i18n="nav.contact">Contact Us</span>
      </a>

      <a class="btn btn-red nav-cta" href="#" onclick="openPrequalModal();return false;">
        <span data-i18n="nav.cta">GET PRE-QUALIFIED NOW</span>
      </a>
    </div>

    <button id="lang-toggle" onclick="toggleLang()" data-current-lang={lang} aria-label="Toggle Language">
      <span class="lang-opt" data-lang="en">EN</span>
      <span class="lang-opt" data-lang="es">ES</span>
    </button>
    <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile nav -->
<div class="nav-mobile-backdrop" id="mobile-backdrop"></div>
<div class="nav-mobile" id="mobile-menu">
  <div class="nm-header">
    <img src="https://mistermortgageusa.com/wp-content/uploads/2025/05/PNG-02.webp" alt="Mister Mortgage USA" class="nm-logo" />
    <button class="nav-mobile-close" id="mobile-close" aria-label="Close menu">&#215;</button>
  </div>
  <nav class="nm-links">
    <a class:list={['nav-link', { active: isActive(nav.home) }]} href={nav.home}>
      <span data-i18n="nav.home">Home</span>
    </a>
    <a class:list={['nav-link', { active: loansActive }]} href={nav.loans}>
      <span data-i18n="nav.loans">Loan Options</span>
    </a>
    <a class:list={['nav-link', { active: isActive(nav.about) }]} href={nav.about}>
      <span data-i18n="nav.about">About Us</span>
    </a>
    <a class:list={['nav-link', { active: isActive(nav.team) }]} href={nav.team}>
      <span data-i18n="nav.team">Team</span>
    </a>
    <a class:list={['nav-link', { active: isActive(nav.contact) }]} href={nav.contact}>
      <span data-i18n="nav.contact">Contact Us</span>
    </a>
  </nav>
  <div class="nm-cta-wrap">
    <a class="btn btn-red" href="#" onclick="openPrequalModal();return false;">
      <span data-i18n="nav.cta">GET PRE-QUALIFIED NOW</span>
    </a>
  </div>
  <div class="nm-contact">
    <a href="tel:+13056151515" class="nm-contact-item">
      <div class="nm-contact-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
      </div>
      <div class="nm-contact-text">
        <span class="nm-contact-label" data-i18n="mobile.call">Call Us</span>
        <span class="nm-contact-value">(305) 615-1515</span>
      </div>
    </a>
    <a href="https://maps.google.com/?q=6030+Bird+Rd,+Miami,+FL+33155" target="_blank" rel="noopener" class="nm-contact-item">
      <div class="nm-contact-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      </div>
      <div class="nm-contact-text">
        <span class="nm-contact-label" data-i18n="mobile.office">Our Office</span>
        <span class="nm-contact-value">6030 Bird Rd, Miami FL</span>
      </div>
    </a>
    <a href="https://wa.me/13052141515?text=Hi!%20I%27d%20like%20to%20learn%20more%20about%20your%20mortgage%20services%20at%20Mister%20Mortgage%20USA." target="_blank" rel="noopener" class="nm-contact-item">
      <div class="nm-contact-icon wa">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
      </div>
      <div class="nm-contact-text">
        <span class="nm-contact-label">WhatsApp</span>
        <span class="nm-contact-value">Chat with us</span>
      </div>
    </a>
  </div>
</div>
